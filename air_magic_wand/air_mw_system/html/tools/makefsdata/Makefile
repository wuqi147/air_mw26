# Project: makefsdata
ifdef CMW_CONFIG
include $(CMW_CONFIG)
else
include $(AIR_MW_DIR)/project/$(PROJECT)/make/config.mk
endif

CC	= gcc
SRC = makefsdata.c
BIN	= makefsdata.bin

# Define the directories
APP_LWIP_DIR = $(OS_PATH)/app/lwip
APP_LWIP_SRC = $(APP_LWIP_DIR)/lwip-2.1.2/src
APP_PORTS_8851 = $(APP_LWIP_DIR)/ports/AIR_8851

WEBPAGE_C_DEF =
ifeq ($(AIR_SUPPORT_IGMP_SNP),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_IGMP_SNP
endif
ifeq ($(AIR_SUPPORT_LP),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_LP
endif
ifeq ($(AIR_SUPPORT_DHCP_SNOOP),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_DHCP_SNOOP
endif
ifeq ($(AIR_SUPPORT_ICMP_CLIENT),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_ICMP_CLIENT
endif
ifeq ($(AIR_SUPPORT_VOICE_VLAN),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_VOICE_VLAN
endif
ifeq ($(AIR_SUPPORT_SNMP),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_SNMP
endif
ifeq ($(AIR_SUPPORT_RSTP),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_STP
endif
ifeq ($(AIR_SUPPORT_MSTP),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_STP
WEBPAGE_C_DEF += -DAIR_SUPPORT_MSTP
endif
ifeq ($(AIR_SUPPORT_MQTTD),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_MQTTD
endif
ifeq ($(AIR_SUPPORT_LLDPD),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_LLDPD
endif
ifeq ($(AIR_SUPPORT_SFP),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_SFP
endif
ifeq ($(AIR_SUPPORT_SFP_DDM),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_SFP_DDM
endif
ifeq ($(AIR_SUPPORT_SURVEILLANCE_VLAN),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_SURVEILLANCE_VLAN
endif
ifeq ($(AIR_SUPPORT_SNTP),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_SNTP
endif
ifeq ($(AIR_SUPPORT_POE),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_POE
endif
ifeq ($(AIR_SUPPORT_ERPS),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_ERPS
endif
ifeq ($(AIR_SUPPORT_CABLE_DIAG),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_CABLE_DIAG
endif
ifeq ($(AIR_SUPPORT_HTTPD_SECURE),ENABLED)
WEBPAGE_C_DEF += -DAIR_SUPPORT_HTTPD_SECURE
endif

INCS = \
	-Iinc \
	-I../../../util/inc \
	-I$(APP_LWIP_DIR) \
	-I$(APP_LWIP_SRC)/include \
	-I$(APP_LWIP_SRC)/core \
	-I$(APP_LWIP_SRC)/apps/http \
	-I$(APP_PORTS_8851)/include \
	-I../../../../../freertos/project/$(PROJECT)

INCS += $(INC)

CFLAGS = $(INCS)  $(HTTPSCHUNKED) $(WEBPAGE_C_DEF)

$(BIN): $(SRC)
	$(CC) $^ -o $@ $(CFLAGS)

all: $(BIN)

clean:
	@rm -f $(OBJ) $(BIN)

.PHONY: all clean
